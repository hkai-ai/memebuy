{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://memebuy.internal/schemas/gallery-template-import.json",
  "title": "GalleryTemplateImport",
  "description": "批量导入 memebuy 后端 GalleryTemplate 表的单模板文件契约。本地产物的图片字段使用本地路径；OSS 最终交付产物使用指定 assets 域名下的 HTTPS URL。topicId / status / sortOrder 由后端导入时决定，不在本文件里产出。",
  "type": "object",
  "additionalProperties": false,
  "required": ["key", "title", "promptTemplate", "inputSchema"],
  "properties": {
    "key": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,59}$",
      "description": "业务唯一键（upsert 依据）。小写字母开头，仅小写字母/数字/连字符，2-60 字符。"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "description": "模板标题。"
    },
    "description": {
      "type": ["string", "null"],
      "maxLength": 300,
      "description": "模板简介，超长请截断到 300 字符。"
    },
    "cover": {
      "type": ["string", "null"],
      "description": "封面图。本地产物使用相对当前 JSON 的文件路径；最终交付产物使用指定 assets 域名下的 HTTPS URL，后端写入 coverUrl。"
    },
    "referenceImage": {
      "type": ["string", "null"],
      "description": "模板自带固定参考图。本地产物使用相对当前 JSON 的文件路径；最终交付产物使用指定 assets 域名下的 HTTPS URL，后端写入 templateImageUrl。它与 inputSchema 的终端用户 image 输入槽无关。"
    },
    "imageSize": {
      "type": "string",
      "pattern": "^\\d{2,4}x\\d{2,4}$",
      "default": "1024x1024",
      "description": "出图尺寸，形如 1024x1024。"
    },
    "imageN": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4,
      "default": 1,
      "description": "单次出图张数。"
    },
    "stageKey": {
      "type": ["string", "null"],
      "maxLength": 60,
      "description": "生成能力 stage 标识（可空）。"
    },
    "promptTemplate": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000,
      "description": "提示词模板【可执行字段，语法固定】。占位为兜底链：{{ term | term | \"字面量默认\" }}，从左到右取第一个非空项。term 是点路径：{{inputId}} 取该输入值；{{selectId.key}} 取选中项 payload[key]；{{stepId.field}} 取预处理步产出的 JSON 字段。双引号内是字面量兜底。所有 term 引用的 head id 必须在 inputSchema 或 preprocessSteps 中已定义。"
    },
    "inputSchema": {
      "type": "array",
      "maxItems": 20,
      "default": [],
      "description": "终端用户填写的输入槽【可执行字段，结构固定】。判别联合，按 type 分 prompt/select/image 三类。数组内 id 唯一。",
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/promptInput" },
          { "$ref": "#/$defs/selectInput" },
          { "$ref": "#/$defs/imageInput" }
        ]
      }
    },
    "preprocessSteps": {
      "type": "array",
      "maxItems": 4,
      "default": [],
      "description": "AI 预处理步【可执行字段，结构固定】。worker 侧异步执行，产出 JSON 供 {{stepId.field}} 引用。无预处理给 []。step id 与 inputSchema 的 id 共享命名空间、不得撞名。判别联合 vision/text。",
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/visionStep" },
          { "$ref": "#/$defs/textStep" }
        ]
      }
    },
    "metadata": {
      "type": "object",
      "description": "所有我方没有专列的模板元数据整包存这里（DB 列 metadata Json?，原样保存、零丢失）。Agent 觉得有价值的分类/风格/版本等都放这。约定额外铺一个扁平 tags 数组，供未来筛选/再识别。",
      "properties": {
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "扁平标签数组（从分类体系铺平），未来按 metadata.tags 筛选。"
        },
        "tagAssignments": {
          "type": "array",
          "maxItems": 40,
          "items": { "$ref": "#/$defs/tagAssignment" },
          "description": "保留标签层级、来源、状态、AI 置信度与外部平台。accepted label 必须同步铺入 metadata.tags。"
        }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "tagAssignment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "dimension", "level", "source", "status"],
      "properties": {
        "tagId": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,79}$" },
        "label": { "type": "string", "minLength": 1, "maxLength": 80 },
        "dimension": { "type": "string", "pattern": "^[a-z][a-z0-9_-]{1,39}$" },
        "level": { "enum": ["category", "tag"] },
        "source": { "enum": ["operator", "template", "ai", "external"] },
        "status": { "enum": ["accepted", "suggested", "rejected"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "provider": { "type": "string", "minLength": 1, "maxLength": 80 },
        "evidence": { "type": "string", "maxLength": 300 }
      }
    },
    "inputId": {
      "type": "string",
      "pattern": "^[a-zA-Z][a-zA-Z0-9_-]{0,39}$",
      "description": "输入/步骤 id：字母开头，仅字母/数字/下划线/连字符，最长 40。"
    },
    "promptInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id", "label"],
      "properties": {
        "type": { "const": "prompt" },
        "id": { "$ref": "#/$defs/inputId" },
        "label": { "type": "string", "minLength": 1, "maxLength": 40 },
        "placeholder": { "type": "string", "maxLength": 120, "default": "" },
        "required": { "type": "boolean", "default": false },
        "suggestions": {
          "type": "array",
          "maxItems": 10,
          "items": { "type": "string", "maxLength": 120 },
          "description": "可选的输入建议词。"
        }
      }
    },
    "selectInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id", "label", "options"],
      "properties": {
        "type": { "const": "select" },
        "id": { "$ref": "#/$defs/inputId" },
        "label": { "type": "string", "minLength": 1, "maxLength": 40 },
        "required": { "type": "boolean", "default": false },
        "options": {
          "type": "array",
          "minItems": 1,
          "maxItems": 30,
          "items": { "$ref": "#/$defs/selectOption" }
        }
      }
    },
    "selectOption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "label"],
      "properties": {
        "value": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120,
          "description": "选中后由 {{selectId}} 注入 prompt 的文本，可写成描述性文案。"
        },
        "label": { "type": "string", "minLength": 1, "maxLength": 40, "description": "给用户看的选项名。" },
        "thumbnail": { "type": "string", "format": "uri", "maxLength": 500, "description": "可选缩略图 URL。" },
        "payload": {
          "type": "object",
          "additionalProperties": { "type": "string", "maxLength": 4000 },
          "description": "选中项的具名附加值：{{selectId.key}} 取 payload[key]（如每个 MBTI code 带 fusion 风格段 + subtitle 副标题）。"
        }
      }
    },
    "imageInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id", "label"],
      "description": "图片输入槽 = 终端用户上传的图（运行时值为 assetId 数组）。不要在这里放模板自带图路径，那个用顶层 referenceImage。",
      "properties": {
        "type": { "const": "image" },
        "id": { "$ref": "#/$defs/inputId" },
        "label": { "type": "string", "minLength": 1, "maxLength": 40 },
        "hint": { "type": "string", "maxLength": 120, "default": "", "description": "上传引导文案，如「请上传正脸清晰照」。" },
        "required": { "type": "boolean", "default": false },
        "maxCount": { "type": "integer", "minimum": 1, "maximum": 6, "default": 1, "description": "最多可传图片数，1 = 单图。" },
        "minWidth": { "type": "integer", "minimum": 64, "maximum": 8192, "description": "可选最低宽度像素。" },
        "minHeight": { "type": "integer", "minimum": 64, "maximum": 8192, "description": "可选最低高度像素。" },
        "private": { "type": "boolean", "default": false, "description": "人脸等敏感图置 true → 走私读桶。" }
      }
    },
    "visionStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id", "stageKey", "imageInputId", "prompt"],
      "description": "视觉预处理：读某 image 输入 → 视觉模型按 prompt 提取 → 产出 JSON（{{stepId.field}} 引用）。",
      "properties": {
        "type": { "const": "vision" },
        "id": { "$ref": "#/$defs/inputId", "description": "步骤 id = 产出变量名。" },
        "stageKey": { "type": "string", "minLength": 1, "maxLength": 60, "description": "视觉能力 AI stage，如 meme.avatar_vl。" },
        "imageInputId": { "$ref": "#/$defs/inputId", "description": "喂给它的 image 输入槽 id，必须指向已定义的 image 槽。" },
        "prompt": { "type": "string", "minLength": 1, "maxLength": 8000, "description": "提取指令，本身也可含 {{输入}}。" },
        "maxOutputTokens": { "type": "integer", "minimum": 256, "maximum": 32000 },
        "cache": { "type": "boolean", "default": true }
      }
    },
    "textStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id", "stageKey", "prompt"],
      "description": "文本改写预处理：按 prompt 改写/扩写文本 → 产出 JSON（{{stepId.field}} 引用）。",
      "properties": {
        "type": { "const": "text" },
        "id": { "$ref": "#/$defs/inputId", "description": "步骤 id = 产出变量名。" },
        "stageKey": { "type": "string", "minLength": 1, "maxLength": 60 },
        "prompt": { "type": "string", "minLength": 1, "maxLength": 8000, "description": "改写指令，可含 {{输入}} 与 {{前序步骤.field}}。" },
        "maxOutputTokens": { "type": "integer", "minimum": 256, "maximum": 32000 },
        "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
        "cache": { "type": "boolean", "default": true }
      }
    }
  }
}
