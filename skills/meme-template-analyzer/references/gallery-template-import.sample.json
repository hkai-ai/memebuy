{
  "key": "mbti-fusion-avatar",
  "title": "MBTI 融合头像",
  "description": "MBTI人格融合头像",
  "cover": "./assets/cover.png",
  "referenceImage": "./assets/style-reference.png",
  "imageSize": "1024x1024",
  "imageN": 1,
  "stageKey": "meme.avatar_gen",
  "inputSchema": [
    {
      "type": "subject",
      "id": "person",
      "label": "头像主体",
      "required": false,
      "text": {
        "defaultValue": "一位年轻人",
        "placeholder": "选择预设或描述人物",
        "allowCustom": true,
        "suggestions": [
          "一位年轻女性",
          "一位年轻男性",
          "一只拟人化宠物"
        ]
      },
      "image": {
        "enabled": true,
        "promptValue": "用户上传图中的主体",
        "hint": "可上传一张主体清晰的参考图",
        "extract": "仅保留主体身份、五官、轮廓、颜色和服饰线索，不继承原图构图。",
        "maxCount": 1,
        "minWidth": 512,
        "minHeight": 512,
        "private": true,
        "sourceOptions": [
          "upload",
          "recent_upload",
          "asset_library"
        ]
      },
      "resolutionStrategy": "image_over_text"
    },
    {
      "type": "select",
      "id": "mbti",
      "label": "MBTI 人格",
      "required": true,
      "options": [
        {
          "value": "理性冷冽的战略家气质，深蓝金属色调，锐利眼神",
          "label": "INTJ 建筑师",
          "payload": {
            "subtitle": "运筹帷幄的孤独设计师",
            "palette": "deep navy, gunmetal, cold silver"
          }
        },
        {
          "value": "热烈张扬的表演者气质，暖橙霓虹，动感光斑",
          "label": "ESFP 表演者",
          "payload": {
            "subtitle": "点燃全场的天生主角",
            "palette": "warm orange, magenta neon, gold sparkle"
          }
        }
      ]
    },
    {
      "type": "prompt",
      "id": "extra",
      "label": "额外风格描述（可选）",
      "placeholder": "例如：赛博朋克、水彩、胶片颗粒",
      "required": false,
      "maxLength": 120,
      "suggestions": [
        "赛博朋克",
        "水彩插画",
        "胶片颗粒感"
      ]
    },
    {
      "type": "image",
      "id": "style_reference",
      "label": "附加风格参考图",
      "hint": "可选，不用于替换主体",
      "required": false,
      "maxCount": 1,
      "private": false
    }
  ],
  "preprocessSteps": [],
  "promptTemplate": "为 {{person | \"一位年轻人\"}} 设计一张 {{mbti}} 风格的头像肖像。整体配色 {{mbti.palette}}，副标题氛围为 {{mbti.subtitle}}。补充要求：{{extra | \"电影级布光，高细节\"}}。",
  "promptEnhancement": {
    "stageKey": "gallery.prompt_rewrite",
    "instruction": "在不改变用户主体和人格选择的前提下，将基础提示词改写为完整、清晰、适合图片网关执行的提示词。上传主体图存在时只继承身份特征，不继承其构图。只输出最终成图；不得显示模板标题、槽位框、组件标签、组件 ID、虚线连线、图例、操作说明、界面元素或任何编辑标注。",
    "referenceField": "referenceImage",
    "lockedConstraints": [
      "主体面部清晰且不被文字遮挡",
      "保持模板参考图的头像构图和风格层级"
    ],
    "preserve": [
      "保持头像裁切",
      "保持面部清晰可见",
      "保持视觉风格层级"
    ],
    "output": {
      "format": "json",
      "promptField": "finalPrompt"
    }
  },
  "metadata": {
    "tags": [
      "头像",
      "MBTI",
      "人脸融合",
      "潮流",
      "MBTI头像"
    ],
    "tagAssignments": [
      {
        "tagId": "tag.mbti-avatar",
        "label": "MBTI头像",
        "dimension": "manual",
        "level": "tag",
        "source": "operator",
        "status": "accepted"
      },
      {
        "label": "潮流头像",
        "dimension": "visual_detail",
        "level": "tag",
        "source": "ai",
        "status": "suggested",
        "confidence": 0.72,
        "evidence": "画面采用高对比潮流头像构图"
      }
    ],
    "category": "avatar/personality-fusion",
    "version": "2.0.0",
    "inputSemantics": {
      "person": {
        "semanticType": "person_identity",
        "defaultStateLabel": "保留默认人物",
        "textInputLabel": "或用文字描述人物",
        "uploadLabel": "上传人物图"
      }
    },
    "presentation": {
      "recommendedOutputRatio": "1:1",
      "referenceImageRemovable": false
    },
    "runtimeRequirements": {
      "subjectInputVersion": 2,
      "supportsMultipleSubjectImages": false,
      "imageSlotAddressing": "input_id"
    }
  }
}
