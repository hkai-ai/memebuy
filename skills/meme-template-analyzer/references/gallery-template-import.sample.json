  "cover": "./assets/cover.png",
  "referenceImage": "./assets/style-reference.png",
  "imageSize": "1024x1024",
  "imageN": 1,
  "stageKey": "meme.avatar_gen",
  "inputSchema": [
    {
      "type": "image",
      "id": "face",
      "label": "你的正脸照",
      "hint": "请上传一张五官清晰的正脸照",
      "required": true,
      "maxCount": 1,
      "minWidth": 512,
      "minHeight": 512,
      "private": true
