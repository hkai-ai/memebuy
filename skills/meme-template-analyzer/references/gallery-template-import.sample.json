{
  "key": "mbti-fusion-avatar",
  "title": "MBTI 融合头像",
  "description": "MBTI人格融合头像",
  "cover": "./assets/cover.png",
  "referenceImage": "./assets/style-reference.png",
  "imageSize": "1024x1024",
  "imageN": 1,
  "stageKey": "meme.avatar_gen",
  "inputSchema": [
    {
      "type": "subject",
      "id": "person",
      "label": "主体",
      "required": false,
      "text": {
        "defaultValue": "一位年轻人",
        "placeholder": "选择预设或描述人物",
        "allowCustom": true,
        "suggestions": [
          "一位年轻女性",
          "一位年轻男性",
          "一只拟人化宠物"
        ]
      },
      "image": {
        "enabled": true,
        "promptValue": "用户上传图中的主体",
        "hint": "可上传一张主体清晰的参考图",
        "extract": "仅保留主体身份、五官、轮廓、颜色和服饰线索，不继承原图构图。",
        "maxCount": 1,
        "minWidth": 512,
        "minHeight": 512,
        "private": true,
        "sourceOptions": [
          "upload",
          "recent_upload",
          "asset_library"
        ]
      },
      "resolutionStrategy": "image_over_text"
    },
    {
      "type": "prompt",
      "id": "accessory",
      "label": "颈前配饰",
      "required": false,
      "suggestions": [
        "粉色领结",
        "红白斜纹领带",
        "珍珠项链"
      ]
    },
    {
      "type": "prompt",
      "id": "headline",
      "label": "标题文字",
      "placeholder": "输入标题文字",
      "required": false,
      "maxLength": 120,
      "suggestions": [
        "保持好奇",
        "今天也很棒",
        "快乐出发"
      ]
    },
    {
      "type": "image",
      "id": "emblem_image",
      "label": "徽章图案",
      "hint": "可选，上传要放入徽章区域的图案",
      "required": false,
      "maxCount": 1,
      "private": false
    }
  ],
  "preprocessSteps": [],
  "promptTemplate": "一幅居中头像海报，{{person | \"一位年轻人\"}}佩戴{{accessory | \"粉色领结\"}}，画面标题写着“{{headline | \"保持好奇\"}}”。",
  "promptEnhancement": {
    "stageKey": "gallery.prompt_rewrite",
    "instruction": "把基础提示词改写成一条完整、可直接执行的图像生成提示词。用户在开放槽位中填写或上传的内容是本次生成的主体意图，必须完整体现。参考图在构图、画幅、裁切、镜头景别、背景、留白、画风、媒介、材质、色调与光影维度上具有最高权限，在画面内容与主体身份维度上不具权限。不要用文字复述参考图中的具体画面内容。只输出最终成图；不得显示模板标题、槽位框、组件标签、组件 ID、虚线连线、图例、操作说明、界面元素或任何编辑标注。",
    "referenceField": "referenceImage",
    "lockedConstraints": [
      "沿用参考图的画幅、裁切、留白、镜头景别与元素位置比例",
      "沿用参考图的媒介质感、材质表现与色彩关系",
      "沿用参考图的前景背景层级、遮挡关系与阅读顺序"
    ],
    "preserve": [
      "主体面部必须清晰可见且不被标题遮挡"
    ],
    "output": {
      "format": "json",
      "promptField": "finalPrompt"
    }
  },
  "metadata": {
    "tags": [
      "头像",
      "MBTI",
      "人脸融合",
      "潮流",
      "MBTI头像"
    ],
    "tagAssignments": [
      {
        "tagId": "tag.mbti-avatar",
        "label": "MBTI头像",
        "dimension": "manual",
        "level": "tag",
        "source": "operator",
        "status": "accepted"
      },
      {
        "label": "潮流头像",
        "dimension": "visual_detail",
        "level": "tag",
        "source": "ai",
        "status": "suggested",
        "confidence": 0.72,
        "evidence": "画面采用高对比潮流头像构图"
      }
    ],
    "category": "avatar/personality-fusion",
    "version": "2.0.0",
    "inputSemantics": {
      "person": {
        "semanticType": "subject_identity",
        "defaultStateLabel": "保留原主体",
        "textInputLabel": "或用文字描述主体",
        "uploadLabel": "上传主体图"
      },
      "accessory": {
        "semanticType": "accessory_content"
      },
      "headline": {
        "semanticType": "text_content"
      },
      "emblem_image": {
        "semanticType": "embedded_image_content"
      }
    },
    "templateSource": {
      "referenceField": "referenceImage",
      "authority": {
        "composition_authority": "high",
        "style_authority": "high",
        "identity_authority": "none"
      }
    },
    "presentation": {
      "recommendedOutputRatio": "1:1",
      "referenceImageRemovable": false
    },
    "runtimeRequirements": {
      "subjectInputVersion": 2,
      "supportsMultipleSubjectImages": false,
      "imageSlotAddressing": "input_id"
    }
  }
}
